# Backend Dockerfile - Development
# This Dockerfile is optimized for development with hot-reloading

FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY tsconfig.json ./

# Install all dependencies (including devDependencies)
RUN npm install --legacy-peer-deps

# Expose backend port
EXPOSE 3001

# Use ts-node-dev for hot-reloading during development
# --respawn: Auto-restart on file changes
# --transpile-only: Skip TypeScript type checking for faster reloads
CMD ["npm", "run", "dev"]
